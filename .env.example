# Supabase API Configuration (REQUIRED)
# Get these from your Supabase project: Settings > API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Note: Service Role Key bypasses Row Level Security (RLS)
# Keep it secret! Never expose it in client-side code.

# Optional: Database Connection (only needed for migrations with Drizzle)
# Get this from: Settings > Database > Connection string > URI
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Email Configuration (optional)
# EMAIL_SMTP=smtp://user:pass@smtp.example.com:587
# SALON_EMAIL=your-email@example.com

# Server Port
PORT=2828
